{
  "version": 5,
  "configurePresets": [
    {
      "name": "macos-qt-debug",
      "displayName": "macOS Qt6 Debug (Apple Silicon)",
      "description": "Clang/Ninja debug build using Qt6 on macOS arm64.",
      "generator": "Ninja",
      "binaryDir": "${sourceDir}/build/macos-qt-debug",
      "condition": {
        "type": "equals",
        "lhs": "${hostSystemName}",
        "rhs": "Darwin"
      },
      "cacheVariables": {
        "CMAKE_BUILD_TYPE": "Debug",
        "CMAKE_PREFIX_PATH": "/opt/homebrew/lib/cmake",
        "CMAKE_OSX_ARCHITECTURES": "arm64",
        "CMAKE_OSX_DEPLOYMENT_TARGET": "14.0"
      }
    }
  ],
  "buildPresets": [
    {
      "name": "macos-qt-debug",
      "configurePreset": "macos-qt-debug"
    }
  ]
}
